{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "Prefer plain, low-friction formatting over presentation-heavy formatting.",
    "Avoid bold emphasis unless explicitly requested or genuinely necessary.",
    "Use inline backticks sparingly and only when they clearly help with exact commands, flags, code, or literals.",
    "Prefer short, clear sentences and compact bullet points over long prose when the task allows it.",
    "Use fenced code blocks for multi-line commands, examples, or snippets.",
    "Keep outputs easy to scan and practical to use.",
    "Do not compress away important meaning or reasoning just to make something shorter.",
    "When editing existing notes or written material, improve and clarify them without casually deleting useful context."
  ],
  "model": "openai/gpt-5.5",
  "default_agent": "general",
  "agent": {
    "general": {
      "description": "Broad general assistant for practical help, questions, and vault-aware work.",
      "mode": "primary",
      "prompt": "{file:agents/general.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "edit": "ask",
        "bash": {
          "rm -rf *": "deny",
          "rm -r *": "deny",
          "rm -f *": "deny",
          "rmdir *": "deny",
          "sudo rm*": "deny",
          "chmod -R *": "deny",
          "chown -R *": "deny",
          "dd *": "deny",
          "mkfs*": "deny",
          "diskutil erase*": "deny",
          "npm publish*": "deny",
          "pnpm publish*": "deny",
          "yarn publish*": "deny",
          "docker push*": "deny",
          "terraform destroy*": "deny",
          "kubectl delete*": "deny",
          "helm uninstall*": "deny",
          "git push --force*": "deny",
          "git reset --hard*": "deny",
          "git clean*": "deny",
          "git branch -D *": "deny",
          "git push*": "ask",
          "git add*": "ask",
          "git commit*": "ask",
          "git checkout*": "ask",
          "git switch*": "ask",
          "git restore*": "ask",
          "git merge*": "ask",
          "git rebase*": "ask",
          "git pull*": "ask",
          "git fetch*": "ask",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git branch*": "allow",
          "git ls-files*": "allow",
          "git grep*": "allow",
          "git rev-parse*": "allow",
          "pwd": "allow",
          "ls": "allow",
          "ls *": "allow",
          "rg *": "allow",
          "wc *": "allow",
          "file *": "allow",
          "stat *": "allow",
          "*>*": "ask",
          "*>>*": "ask",
          "*|*": "ask",
          "*`*": "ask",
          "*$(*": "ask",
          "* xargs *": "ask",
          "tee *": "ask",
          "git status* && git diff*": "allow",
          "git status* && git diff --stat*": "allow",
          "git status* && git log*": "allow",
          "git status*; git diff*": "allow",
          "pwd && ls*": "allow",
          "pwd; ls*": "allow",
          "*&&*": "ask",
          "*;*": "ask",
          "*": "ask"
        },
        "task": "deny"
      },
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "webfetch": true,
        "websearch": true,
        "question": true,
        "skill": true,
        "todowrite": true,
        "edit": true,
        "bash": true,
        "task": false
      }
    },
    "learning": {
      "description": "Higher-order learning assistant for understanding, schemas, recall, and application.",
      "mode": "primary",
      "prompt": "{file:agents/learning.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "edit": "ask",
        "task": "deny"
      },
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "webfetch": true,
        "websearch": true,
        "question": true,
        "skill": true,
        "todowrite": true,
        "edit": true,
        "bash": true,
        "task": false
      }
    },
    "processing": {
      "description": "Vault processing assistant for inbox and active notes with careful preservation.",
      "mode": "primary",
      "prompt": "{file:agents/processing.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "question": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "webfetch": "ask",
        "websearch": "ask",
        "edit": "ask",
        "task": "deny"
      },
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "list": true,
        "webfetch": true,
        "websearch": true,
        "question": true,
        "skill": true,
        "todowrite": true,
        "edit": true,
        "bash": true,
        "task": false
      }
    },
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    }
  },
  "permission": {
    "read": "allow",
