  "provider": {
    "LocalAI": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1",
        "apiKey": "dummy"
      },
      "models": {
        "gemma4:e2b": {
          "name": "gemma4:e2b",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  }
